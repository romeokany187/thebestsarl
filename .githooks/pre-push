#!/usr/bin/env bash
# pre-push hook: run build and abort push on failure
set -euo pipefail

echo "Running pre-push build..."

# try to run the project's MySQL-targeted build script
if npm run build:mysql --silent; then
  echo "Build succeeded — continuing push."
  exit 0
else
  echo "Build failed — aborting push. Fix the build and try again." >&2
  exit 1
fi
