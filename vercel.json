{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "crons": [
    {
      "path": "/api/cron/reports/daily",
      "schedule": "10 18 * * *"
    },
    {
      "path": "/api/cron/reports/weekly",
      "schedule": "20 18 * * 1"
    },
    {
      "path": "/api/cron/reports/monthly",
      "schedule": "30 18 1 * *"
    },
    {
      "path": "/api/payments/unpaid-alerts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/payments/unpaid-alerts",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/payments/unpaid-alerts",
      "schedule": "0 16 * * *"
    }
  ]
}
